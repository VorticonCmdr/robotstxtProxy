{
  "name": "robotstxt-proxy",
  "version": "0.1.0",
  "description": "A Node.js forward HTTP(S) proxy that allows or blocks requests based on the target origin's robots.txt.",
  "type": "module",
  "main": "src/server.js",
  "bin": {
    "robotstxt-proxy": "src/server.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "google-robotstxt-parser": "^1.2.0"
  },
  "optionalDependencies": {
    "node-forge": "^1.3.1"
  }
}
